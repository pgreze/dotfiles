#!/usr/bin/env bash
#
# Run the first argument as a bash script, with following arguments
# passed as positional parameters ($1, $2, ...).
#
# Purpose: test bash-specific behavior from a non-bash shell (e.g. zsh)
# without creating a file.
#

set -o errexit -o errtrace -o nounset -o pipefail

usage() {
    printf 'Usage: %s content [<arg>...]\n\n' "$(basename "$0")"
    echo 'Example: bash-run '\''pargs "$@"'\'' "hello world" haha plop'
    exit "${1:-0}"
}

if [[ $# -eq 0 ]]; then
    usage 1
elif [[ "$1" == "-h" || "$1" == "--help" ]]; then
    usage 0
fi

script="$1"
shift
exec bash -c "$script" "$(basename "$0")" "$@"
