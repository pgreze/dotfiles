#!/usr/bin/env bash
# ai — multi-CLI launcher with profile selection
# To add a CLI: append to CLIS/CLI_LABELS, define <NAME_UPPER>_PROFILES array

CLIS=("claude" "codex")
CLI_LABELS=("Claude" "Codex")

# Profile format: "name|flags|description"
CLAUDE_PROFILES=(
    "quick|--model sonnet --effort low|Fast answers, simple tasks"
    "standard|--model sonnet --effort high|Everyday development"
    "max|--model opus --effort max|Best quality, hard problems"
)
CODEX_PROFILES=(
    "quick|--model gpt-5.4-mini|Fast answers, simple tasks"
    "standard|--model gpt-5.4|Everyday development"
    "max|--model gpt-5.5|Best quality, hard problems"
)

# Precompute uppercase CLI names for array lookups
CLI_VARS=()
for c in "${!CLIS[@]}"; do
    CLI_VARS+=("$(echo "${CLIS[$c]}" | tr '[:lower:]' '[:upper:]')_PROFILES")
done

# Build flat index of all (cli_idx|profile_idx) pairs
INDEX=()
for c in "${!CLIS[@]}"; do
    var="${CLI_VARS[$c]}[@]"
    profiles=("${!var}")
    for p in "${!profiles[@]}"; do
        INDEX+=("$c|$p")
    done
done

cursor=1  # Claude standard
total=${#INDEX[@]}

draw() {
    printf '\033[H\033[J'
    printf '\n  \033[1;36mai\033[0m — select a profile\n\n'
    local prev_cli=-1
    for i in "${!INDEX[@]}"; do
        IFS='|' read -r c p <<< "${INDEX[$i]}"
        if [[ $c -ne $prev_cli ]]; then
            [[ $prev_cli -ge 0 ]] && printf '\n'
            printf '  \033[2m%s\033[0m\n' "${CLI_LABELS[$c]}"
            prev_cli=$c
        fi
        local var="${CLI_VARS[$c]}[$p]"
        IFS='|' read -r name flags desc <<< "${!var}"
        if [[ $i -eq $cursor ]]; then
            printf '  \033[1;33m›\033[0m \033[1m%-9s\033[0m \033[33m%-32s\033[0m %s\n' "$name" "$flags" "$desc"
        else
            printf '    %-9s \033[2m%-32s %s\033[0m\n' "$name" "$flags" "$desc"
        fi
    done
    printf '\n  \033[2m↑ ↓ navigate   Enter launch   q quit\033[0m\n'
}

restore() { printf '\033[?1049l\033[?25h'; }
trap restore EXIT
trap 'exit 130' INT TERM

printf '\033[?1049h\033[?25l'
draw

while true; do
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
        IFS= read -rsn1 -t0.1 k2 || true
        [[ "$k2" == '[' ]] && { IFS= read -rsn1 -t0.1 k3 || true; key="[$k3"; }
    fi
    case "$key" in
        '[A') cursor=$(( (cursor - 1 + total) % total )) ;;
        '[B') cursor=$(( (cursor + 1) % total )) ;;
        $'\n'|$'\r'|'') break ;;
        q|Q) exit 0 ;;
    esac
    draw
done

restore
trap - EXIT

IFS='|' read -r c p <<< "${INDEX[$cursor]}"
var="${CLI_VARS[$c]}[$p]"
IFS='|' read -r _ flags _ <<< "${!var}"
IFS=' ' read -ra flags_arr <<< "$flags"
cli="${CLIS[$c]}"

printf '\033[2m  launching: %s %s\033[0m\n\n' "$cli" "$flags"
exec "$cli" "${flags_arr[@]}" "$@"
